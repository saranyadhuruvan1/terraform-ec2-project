# Terraform directories
.terraform/
.terraform.lock.hcl

# Terraform state files
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.backup

# Crash logs
crash.log

# Local environment files
#*.tfvars
*.auto.tfvars

# Ignore environment-specific .terraform folders
environments/*/.terraform/
environments/*/.terraform.lock.hcl
environments/*/terraform.tfstate
environments/*/terraform.tfstate.backup
